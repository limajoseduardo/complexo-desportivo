{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data for utentes, professors, and staff",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "n": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "professor", "staff", "utente"] },
        "cargo": { "type": "string" },
        "img": { "type": "string" },
        "location": { "type": "string" },
        "isInside": { "type": "boolean" },
        "formacao": { "type": "string" },
        "experiencia": { "type": "string" },
        "cedula": { "type": "string" },
        "lema": { "type": "string" },
        "phone": { "type": "string" },
        "nif": { "type": "string" },
        "modalidade": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Exercicio": {
      "title": "Exercise",
      "description": "Exercise definition with multi-language and muscle targeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nomePT": { "type": "string" },
        "nomeEN": { "type": "string" },
        "grupo": { "type": "string" },
        "primaryMuscles": { "type": "array", "items": { "type": "string" } },
        "secondaryMuscles": { "type": "array", "items": { "type": "string" } },
        "desc": { "type": "string" },
        "link": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["nomePT", "grupo", "link"]
    },
    "OperationalLog": {
      "title": "Operational Log",
      "description": "Pool water quality and environment logs",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "tempAgua": { "type": "string" },
        "utaHum": { "type": "string" },
        "cl": { "type": "string" },
        "ph": { "type": "string" },
        "tecnico": { "type": "string" }
      },
      "required": ["timestamp", "tempAgua", "ph"]
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "Historical record of entries and exits",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "modalidade": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "zone": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["userId", "checkIn", "date"]
    },
    "Aula": {
      "title": "Agenda Class",
      "description": "Weekly schedule entry",
      "type": "object",
      "properties": {
        "modalidade": { "type": "string" },
        "categoria": { "type": "string" },
        "diaSemana": { "type": "number" },
        "horaInicio": { "type": "string" },
        "horaFim": { "type": "string" },
        "professor": { "type": "string" },
        "vagas": { "type": "number" },
        "sala": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["modalidade", "diaSemana", "horaInicio", "horaFim"]
    }
  },
  "firestore": {
    "artifacts/{appId}/public/data/agenda/{aulaId}": {
      "schema": "Aula",
      "description": "Store weekly classes schedule"
    },
    "artifacts/{appId}/public/data/logs_acesso/{logId}": {
      "schema": "AccessLog",
      "description": "Store check-in and check-out logs"
    },
    "artifacts/{appId}/public/data/users/{userId}": {
      "schema": "User",
      "description": "Store user profile documents"
    },
    "artifacts/{appId}/public/data/exercicios/{exercicioId}": {
      "schema": "Exercicio",
      "description": "Exercise bank"
    },
    "artifacts/{appId}/public/data/conversas/{chatId}/messages/{msgId}": {
      "schema": { "type": "object", "properties": { "text": { "type": "string" }, "senderId": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" }, "read": { "type": "boolean" } } },
      "description": "Chat messages"
    },
    "artifacts/{appId}/public/data/saude/{metricId}": {
      "schema": { "type": "object" },
      "description": "Health metrics"
    },
    "artifacts/{appId}/public/data/refeicoes/{mealId}": {
      "schema": { "type": "object" },
      "description": "Meal logs"
    },
    "artifacts/{appId}/public/data/logs/{logId}": {
      "schema": "OperationalLog",
      "description": "Operational and maintenance logs"
    },
    "artifacts/{appId}/public/data/bugs/{bugId}": {
      "schema": { "type": "object" },
      "description": "User bug reports"
    }
  }
}
