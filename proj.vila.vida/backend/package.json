{
  "name": "complexo-desportivo-backend",
  "version": "1.0.0",
  "description": "Backend API for Complexo Desportivo de Vila de Rei",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "jest",
    "migrate": "node dist/database/migrations.js",
    "seed": "node dist/database/seeders.js"
  },
  "keywords": [
    "sports",
    "management",
    "vila-de-rei"
  ],
  "author": "Complexo Desportivo",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-cors": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.1.2",
    "pg": "^8.11.3",
    "pg-migrate": "^1.0.0",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "pino": "^8.17.1",
    "axios": "^1.6.2",
    "nodemailer": "^6.9.7",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.45",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5",
    "serialport": "^11.0.1",
    "mqtt": "^5.3.2",
    "socket.io": "^4.7.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
