# Database Configuration
DB_PASSWORD=complexoSecureDB2024
DB_HOST=postgres
DB_PORT=5432
DB_NAME=complexo_desportivo

# Redis Configuration
REDIS_PASSWORD=redisSecure2024
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=complexoDesportivo2024SuperSecureKeyForAuthentication
JWT_EXPIRY=24h

# API Configuration
API_URL=https://api.buildlab.pt
FRONTEND_URL=https://www.buildlab.pt
NODE_ENV=production

# Grafana Configuration
GRAFANA_PASSWORD=grafanaAdmin2024

# RFID Configuration
ENABLE_RFID=true
RFID_SERIAL_PORT=/dev/ttyUSB0

# SMTP Configuration (for notifications)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@buildlab.pt

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/letsencrypt/live/buildlab.pt
SSL_KEY_PATH=/etc/letsencrypt/live/buildlab.pt

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Domain Configuration
DOMAIN=buildlab.pt
SUBDOMAIN_API=api.buildlab.pt
SUBDOMAIN_WWW=www.buildlab.pt

# Session Configuration
SESSION_SECRET=complexoSessionSecret2024
SESSION_TIMEOUT=3600000

# CORS Configuration
CORS_ORIGIN=https://www.buildlab.pt
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
