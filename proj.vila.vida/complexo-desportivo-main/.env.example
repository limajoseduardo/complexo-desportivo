# Obrigatório: chave da API Gemini AI
GEMINI_API_KEY=COLOCA_AQUI_A_TUA_CHAVE_GEMINI

# Base URL da app (/ para VM, /complexo-desportivo/ para GitHub Pages)
VITE_BASE_URL=/

# Firebase Emulator (apenas para desenvolvimento local)
